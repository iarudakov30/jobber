  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "generate-ts-proto": "grpc_tools_node_protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./types ./proto/*.proto --ts_proto_opt=nestJs=true"
  },
  "nx": {
    "targets": {
      "generate-ts-proto": {
        "inputs": [
          "{workspaceRoot}/proto/*.proto"
        ],
        "cache": true
      }
    }
