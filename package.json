    "axios": "1.13.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "module-alias": "^2.3.4",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "ts-proto": "^2.11.4",
    "uuid": "^14.0.0"
  },
  "_moduleAliases": {
    "@jobber/grpc": "dist/libs/grpc/main",
